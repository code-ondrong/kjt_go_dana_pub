{
  "permissions": {
    "allow": [
      "Bash(go mod tidy:*)",
      "Bash(go build:*)",
      "Bash(go get:*)",
      "WebFetch(domain:dashboard.dana.id)",
      "Bash(go list:*)",
      "Bash(go mod graph:*)",
      "Bash(curl:*)",
      "Bash(go doc:*)",
      "Bash(find:*)",
      "Bash(ls:*)",
      "WebSearch",
      "WebFetch(domain:api.github.com)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "WebFetch(domain:github.com)"
    ]
  },
  "mcpServers": {
    "DANA-MCP-INTEGRATION": {
      "command": "npx",
      "args": [
        "mcp-remote",
        "https://dana-mcp.dana.id/sse"
      ]
    }
  }
}
