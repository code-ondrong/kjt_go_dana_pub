# ============================================================
# DANA QR MCP Server - Konfigurasi Environment
# Salin file ini menjadi .env dan isi dengan nilai yang benar
# ============================================================

# Environment: sandbox | production
DANA_ENV=sandbox

# Credentials dari DANA Developer Portal
# https://devportal.dana.id/
DANA_PARTNER_ID=YOUR_PARTNER_ID_DARI_DANA
DANA_CLIENT_ID=YOUR_CLIENT_ID
DANA_CLIENT_SECRET=YOUR_CLIENT_SECRET

# RSA Keys (format PEM atau base64 tanpa header/footer)
# Private key untuk signing request
DANA_PRIVATE_KEY=-----BEGIN RSA PRIVATE KEY-----
# ...isi key Anda...
# -----END RSA PRIVATE KEY-----

# Public key DANA untuk verifikasi notifikasi
DANA_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----
# ...isi key Anda...
# -----END PUBLIC KEY-----

# Server
SERVER_HOST=0.0.0.0
SERVER_PORT=8080
