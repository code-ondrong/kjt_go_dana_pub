# ============================================================
# DANA Payment Gateway Server - Environment Configuration
# Copy this file to .env and fill with your actual values
# ============================================================

# Environment: sandbox | production
DANA_ENV=sandbox

# ============================================================
# REQUIRED FOR PAYMENT GATEWAY UAT
# ============================================================

# Partner ID from DANA Developer Portal
# https://devportal.dana.id/
DANA_PARTNER_ID=YOUR_PARTNER_ID

# Merchant ID (required for Payment Gateway)
DANA_MERCHANT_ID=YOUR_MERCHANT_ID

# RSA Private Key for signing SNAP requests (PEM format)
# Must be PKCS#8 format
DANA_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----
# ... your private key ...
# -----END PRIVATE KEY-----

# Channel ID for Payment Gateway (default: 95221)
CHANNEL_ID=95221

# Origin URL (required for Merchant Management API)
# Must match the domain registered with DANA
ORIGIN=http://localhost:8888

# ============================================================
# OPTIONAL / LEGACY CREDENTIALS
# ============================================================

# Client ID (may be same as Partner ID or different)
DANA_CLIENT_ID=YOUR_CLIENT_ID

# Client Secret (for SDK authentication)
DANA_CLIENT_SECRET=YOUR_CLIENT_SECRET

# Public key DANA for webhook signature verification
DANA_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----
# ... DANA's public key ...
# -----END PUBLIC KEY-----

# Shop ID (for Disbursement API)
SHOP_ID=YOUR_SHOP_ID

# Division ID (optional)
DIVISION_ID=YOUR_DIVISION_ID

# ============================================================
# SERVER CONFIGURATION
# ============================================================

SERVER_HOST=0.0.0.0
SERVER_PORT=8888

# ============================================================
# PAYMENT GATEWAY UAT CHECKLIST
# ============================================================
# [ ] DANA_PARTNER_ID filled and valid
# [ ] DANA_MERCHANT_ID filled and valid
# [ ] DANA_PRIVATE_KEY in correct PEM format
# [ ] CHANNEL_ID set (default 95221)
# [ ] ORIGIN matches registered domain
# [ ] DANA_ENV set to sandbox for UAT
# [ ] Webhook endpoint /webhook/dana accessible from internet
# [ ] Server port matches ORIGIN port (if localhost)
